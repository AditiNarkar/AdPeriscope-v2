generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String?
  image      String?
  workspaces Workspace[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Workspace {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  brandBrief  String?
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitors Competitor[]
  agentRuns   AgentRun[]
  painPoints  PainPoint[]
  reports     Report[]
  sources     SourceDocument[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
}

model Competitor {
  id          String    @id @default(cuid())
  name        String
  url         String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signals     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AgentRun {
  id          String      @id @default(cuid())
  agent       AgentType
  status      RunStatus   @default(PENDING)
  input       Json
  output      Json?
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model SourceDocument {
  id          String     @id @default(cuid())
  type        SourceType
  title       String
  url         String
  text        String
  metadata    Json?
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([workspaceId, url])
  @@index([workspaceId])
  @@index([type])
}

model PainPoint {
  id          String   @id @default(cuid())
  theme       String
  frequency   Int
  intensity   Int
  source      String
  quote       String
  embedding   Unsupported("vector")?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Report {
  id          String    @id @default(cuid())
  title       String
  type        String
  url         String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

enum AgentType {
  SEO
  COMPETITOR
  AUDIENCE
  PERSONA
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum SourceType {
  WEB
  REDDIT
  YOUTUBE
  RSS
}
