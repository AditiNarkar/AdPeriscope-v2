generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  image       String?
  memberships Membership[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Workspace {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  brandBrief  String?
  memberships Membership[]
  competitors Competitor[]
  agentRuns   AgentRun[]
  painPoints  PainPoint[]
  reports     Report[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Membership {
  id          String    @id @default(cuid())
  role        Role      @default(MEMBER)
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Competitor {
  id          String    @id @default(cuid())
  name        String
  url         String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signals     Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AgentRun {
  id          String      @id @default(cuid())
  agent       AgentType
  status      RunStatus   @default(PENDING)
  input       Json
  output      Json?
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model PainPoint {
  id          String   @id @default(cuid())
  theme       String
  frequency   Int
  intensity   Int
  source      String
  quote       String
  embedding   Unsupported("vector")?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Report {
  id          String    @id @default(cuid())
  title       String
  type        String
  url         String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AgentType {
  SEO
  COMPETITOR
  AUDIENCE
  PERSONA
  CONTENT
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
